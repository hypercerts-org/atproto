# Sign Up URL (PDS URL)
#SIGN_UP_URL=https://bsky.social
SIGN_UP_URL=https://pds-eu-west4.test.certified.app

# SDS Server URL
SDS_SERVER_URL=https://sds-eu-west4.test.certified.app
